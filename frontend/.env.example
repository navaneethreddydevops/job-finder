# Frontend build-time configuration (Vite)
#
# Base URL of the backend API.
# - Local dev: leave UNSET. Vite proxies /api -> http://localhost:8000 (see vite.config.js).
# - Vercel production: set to the FastAPI Cloud backend origin (no trailing slash), e.g.
#     VITE_API_BASE_URL=https://job-finder.fastapicloud.dev
#
# This is baked into the bundle at build time, so set it in the Vercel project's
# Environment Variables before deploying.
VITE_API_BASE_URL=
