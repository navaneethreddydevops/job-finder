# Job Finder Docker Compose Configuration
# ===========================================
#
# IMPORTANT: This project uses CLAUDE OAUTH authentication ONLY.
#
# The backend authenticates via the Claude CLI's stored OAuth login (~/.claude),
# NOT an API key. The backend intentionally drops ANTHROPIC_API_KEY and
# ANTHROPIC_AUTH_TOKEN from the environment so the SDK-spawned `claude` CLI
# always uses OAuth.
#
# To set up authentication:
# 1. Ensure you have the Claude CLI installed: https://github.com/anthropics/claude-cli
# 2. Run: claude login
# 3. This creates ~/.claude with your authentication credentials
# 4. The Docker Compose setup will mount this directory into the container
#
# Configuration Options:
# =====================

# Backend Configuration
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Claude Authentication Configuration
#
# Path to your Claude CLI credentials directory.
# This directory must contain valid Claude authentication.
#
# Common locations:
# - macOS/Linux: ~/.claude (use ~/.claude or $HOME/.claude)
# - Windows: %USERPROFILE%\.claude
#
# The Docker Compose file will mount this as read-only into the container.
# IMPORTANT: This directory must exist and contain valid credentials!
#
# Default: ./.claude (copies credentials into the repo during setup)
# Override: export CLAUDE_CONFIG_DIR=$HOME/.claude
CLAUDE_CONFIG_DIR=./.claude

# API Host Configuration
#
# Used by the frontend to connect to the backend.
# - For local development: localhost
# - For Docker network: backend (service name)
# - For remote deployment: your-domain.com or your-server-ip
API_HOST=localhost

# Database Path (optional, SQLite only)
# DATABASE_PATH=/data/jobs.db

# Job search APIs (Exa + Tavily)
# ===========================================
# The job_scout subagents fetch listings via the Exa and Tavily search APIs (far better
# recall than the built-in WebSearch). Set both keys here for local dev (this file's real
# counterpart, .env, is git-ignored) and as Render secrets for production.
#   Exa:    https://dashboard.exa.ai  → API Keys
#   Tavily: https://app.tavily.com    → API Keys
EXA_API_KEY=
TAVILY_API_KEY=

# ===========================================
# Cloud deployment (Vercel + Render + Neon)
# ===========================================
#
# These are set in the Render / Vercel dashboards, NOT committed. Listed here for reference.
#
# --- Render backend (see render.yaml + backend/Dockerfile.render) ---
#
# CLAUDE_CODE_OAUTH_TOKEN — long-lived Claude OAuth token (OAuth only, never an API key).
#   Generate locally:  claude setup-token
#   Then paste the value into the Render service's environment.
# CLAUDE_CODE_OAUTH_TOKEN=
#
# DATABASE_URL — Neon Postgres connection string. When set (postgres:// or postgresql://),
#   the backend uses Postgres instead of SQLite. Include ?sslmode=require for Neon.
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
#
# --- Vercel frontend (see frontend/vercel.json + frontend/.env.example) ---
#
# VITE_API_BASE_URL — origin of the Render backend, baked into the build.
#   e.g. https://job-finder-api.onrender.com  (leave unset for local dev)
