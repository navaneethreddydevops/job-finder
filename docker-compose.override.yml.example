# Docker Compose Override Example
# ================================
# Copy this to docker-compose.override.yml to customize for your environment
#
# Docker Compose automatically loads docker-compose.override.yml if it exists,
# merging it with docker-compose.yml. This allows per-developer customization
# without modifying the main compose file.
#
# Tip: Add docker-compose.override.yml to .gitignore (already done)

# Example 1: Development with volume mounts for hot reload
# (Uncomment and customize as needed)

# version: '3.8'
# services:
#   backend:
#     volumes:
#       # Mount source code for live reload with uvicorn --reload
#       - ./backend:/app/backend
#       - ./pyproject.toml:/app/pyproject.toml
#       - ./uv.lock:/app/uv.lock
#
#   frontend:
#     # For development, you might want to run the dev server locally instead
#     # Comment out this service and run: cd frontend && npm run dev
#     # ports:
#     #   - "5173:5173"  # Vite dev server port

# Example 2: Different ports for running multiple instances
# version: '3.8'
# services:
#   backend:
#     ports:
#       - "9000:8000"  # Run on port 9000 instead
#
#   frontend:
#     ports:
#       - "3000:80"    # Run on port 3000 instead

# Example 3: Production-like configuration with resource limits
# version: '3.8'
# services:
#   backend:
#     deploy:
#       resources:
#         limits:
#           cpus: '1'
#           memory: 512M
#         reservations:
#           cpus: '0.5'
#           memory: 256M
#
#   frontend:
#     deploy:
#       resources:
#         limits:
#           cpus: '0.5'
#           memory: 256M
#         reservations:
#           cpus: '0.25'
#           memory: 128M

# Example 4: Logging configuration
# version: '3.8'
# services:
#   backend:
#     logging:
#       driver: "json-file"
#       options:
#         max-size: "10m"
#         max-file: "3"
#
#   frontend:
#     logging:
#       driver: "json-file"
#       options:
#         max-size: "10m"
#         max-file: "3"

# Example 5: Environment-specific configuration
# version: '3.8'
# services:
#   backend:
#     environment:
#       - LOG_LEVEL=DEBUG
#       - API_TIMEOUT=60
#
#   frontend:
#     environment:
#       - VITE_API_URL=http://backend:8000

# For more information on Docker Compose overrides:
# https://docs.docker.com/compose/compose-file/compose-file-v3/#compose-file-v32
