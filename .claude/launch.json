{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "backend.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "MCP Server",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "backend/mcp_server.py"],
      "port": null
    }
  ]
}
